# =================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# =================================================================
# 📦 Node
# =================================================================
node_modules/
.next/
dist/
build/

