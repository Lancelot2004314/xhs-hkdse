# =================================================================
# 🔒 SECRETS — never commit
# =================================================================
webapp/config/app_config.json
config/app_config.json
secrets.yaml
.env
.env.*
!.env.example
*.key
*.pem

# Login cookies (xhs-mcp)
xhs-mcp/cookies.json

# =================================================================
# 🗑  Local runtime artifacts
# =================================================================
# Generated covers / body images (per-run)
webapp/cache/images/
covers/output/

# Local task history (per-user drafts)
webapp/cache/task_history.json
webapp/cache/*.json
!webapp/cache/.keep

# Logs
*.log
webapp/app.log
webapp/logs/
xhs-mcp/*.log

